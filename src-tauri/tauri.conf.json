{
    "build":  {
                  "beforeBuildCommand":  "",
                  "beforeDevCommand":  "",
                  "devPath":  "http://localhost:5180",
                  "distDir":  "../frontend/dist"
              },
    "package":  {
                    "productName":  "Chronicle",
                    "version": "3.0.0"
                },
    "tauri":  {
                  "allowlist":  {
                                    "window":  {
                                                   "all":  true
                                               },
                                    "dialog":  {
                                                   "open":  true,
                                                   "save":  true
                                               },
                                    "shell":  {
                                                  "open":  true
                                              },
                                    "path":  {
                                                 "all":  true
                                             },
                                    "fs":  {
                                               "writeFile":  true,
                                               "scope":  [
                                                             "$DOCUMENT/**",
                                                             "$APPDATA/**"
                                                         ]
                                           }
                                },
                  "bundle":  {
                                 "active":  true,
                                 "identifier":  "com.chronicle.app",
                                 "icon":  [
                                              "icons/32x32.png",
                                              "icons/128x128.png",
                                              "icons/128x128@2x.png",
                                              "icons/icon.icns",
                                              "icons/icon.ico"
                                          ],
                                 "windows":  {
                                                 "allowDowngrades":  true
                                             }
                             },
                  "security":  {
                                   "csp":  null
                               },
                  "windows":  [
                                  {
                                      "label":  "main",
                                      "title":  "Chronicle",
                                      "width":  1200,
                                      "height":  800,
                                      "minWidth":  900,
                                      "minHeight":  600,
                                      "resizable":  true,
                                      "fullscreen":  false,
                                      "fileDropEnabled":  false,
                                      "decorations":  false
                                  }
                              ]
              }
}
